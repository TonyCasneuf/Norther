<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AT KIT</title>

<link rel="stylesheet" href="index.css">

<style>

input[type="checkbox"]{
    transform:scale(1.5);
    margin-right:12px;
}

textarea{
    width:100%;
    height:140px;
    padding:10px;
    border-radius:10px;
    font-size:16px;
    box-sizing:border-box;
}

button{
    width:100%;
    padding:15px;
    background:#0057A8;
    color:white;
    border:none;
    border-radius:10px;
    font-size:18px;
    cursor:pointer;
}

button:disabled{
    background:#999;
    cursor:not-allowed;
}

</style>

</head>

<body>

<header>
    <h1>NORTHER</h1>
    <h2>EFA KIT 1 - AT KIT</h2>
</header>

<div class="container">

<div class="kit">

<h2>Inventory</h2>

<p><label><input type="checkbox">LOTO BOX</label></p>

<p><label><input type="checkbox">LOCK OUT LOCKS</label></p>

<p><label><input type="checkbox">LOCK OUT ACCESSORIES</label></p>

<p><label><input type="checkbox">VOLTAGE TESTER</label></p>

<p><label><input type="checkbox">PROVE UNIT</label></p>

<p><label><input type="checkbox">HIGH VOLTAGE GLOVES</label></p>

<p><label><input type="checkbox">FLUKE</label></p>

<h3>Missing / Remarks</h3>

<textarea placeholder="Describe what is missing or damaged..."></textarea>

<br><br>

<button id="saveBtn" disabled>
Scan NFC tag to enable saving
</button>

</div>

</div>

<script>

let authenticated=false;

function enableEditing(){

    authenticated=true;

    const btn=document.getElementById("saveBtn");

    btn.disabled=false;

    btn.innerHTML="Save";

}

document.getElementById("saveBtn").onclick=function(){

    if(!authenticated){

        alert("Scan the NFC tag first.");

        return;

    }

    alert("Inventory saved.");

};

</script>

</body>
</html>
